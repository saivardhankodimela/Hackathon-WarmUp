# Google AI Studio
GOOGLE_API_KEY=your_gemini_api_key_here

# Firebase / GCP
# To use service account, provide path to JSON or define env variables
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=your-project-id

# FastAPI Config
APP_ENV=development
SECRET_KEY=your-jwt-fallback-or-session-secret
CORS_ORIGINS=["http://localhost:3000"]
